# API
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# Database (async URL for API; worker uses sync variant automatically in code)
DATABASE_URL=postgresql+psycopg://wce:wce@localhost:5432/wce

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Orchestration
BOOKING_MAX_RETRIES=5
BOOKING_RETRY_BACKOFF_BASE_SECONDS=30
# Set to 1 to simulate external failure (calendar step) for retry/DLQ demos
SIMULATE_EXTERNAL_FAILURE=0

# CORS — comma-separated list of allowed frontend origins
# Add your Vercel URL after deploying, e.g.:
# ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
